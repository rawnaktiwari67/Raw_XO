PORT=5000
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.mongodb.net/xo-universe?retryWrites=true&w=majority
CLERK_PUBLISHABLE_KEY=pk_live_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_live_your_clerk_secret_key
JWT_SECRET=your-super-secret-jwt-key-256-bits-minimum-change-this
GAME_SECRET=your-game-hmac-secret-change-this
GAME_ARTIST_QUERY=the weeknd, kanye west, travis scott, drake
GAME_ITUNES_COUNTRY=us
GAME_ITUNES_LIMIT=40
GAME_ITUNES_TIMEOUT_MS=4500
GAME_MAX_QUERY_TERMS=6
GAME_TRACK_CACHE_MS=600000
# Groq LLM key for the AI trivia chat and game hints (/api/v1/ai/*).
# Free at https://console.groq.com — no card required. Leave empty to run
# without AI features (those routes return 503, everything else works).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
GAME_SPOTIFY_MARKET=US
GAME_SPOTIFY_TRACK_SEARCH=false
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,https://your-vercel-domain.vercel.app
ADMIN_USER_IDS=
REQUIRE_AUTH_FOR_CULTURE_WRITES=false
