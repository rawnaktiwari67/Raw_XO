VITE_API_URL=/api/v1
VITE_CLERK_PUBLISHABLE_KEY=pk_live_your_clerk_publishable_key
VITE_APPLE_MUSIC_COUNTRY=IN

# Umami analytics (privacy-friendly, cookie-free). Get these from your Umami
# Cloud dashboard (umami.is): the Website ID is required to enable tracking;
# VITE_UMAMI_SRC defaults to the Umami Cloud script and only needs setting if
# you self-host. Analytics only load in production builds.
VITE_UMAMI_WEBSITE_ID=your-umami-website-id
VITE_UMAMI_SRC=https://cloud.umami.is/script.js
