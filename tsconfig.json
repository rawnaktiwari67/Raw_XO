{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node"
  },
  "include": [
    "api/**/*",
    "server/src/**/*"
  ],
  "exclude": [
    "node_modules",
    "client",
    "server/dist",
    "dist",
    "server/src/**/*.test.ts"
  ]
}
